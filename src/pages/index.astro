---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";

const kairosDescription =
  "As a frontend developer at Kairos DS, I played a key role in developing responsive web applications using Angular and Lit, ensuring optimal user experiences. Collaborating with cross-functional teams, I contributed to the implementation of front-end solutions. Engaging in agile development processes, I consistently delivered high-quality software within sprint timelines.";
const theCocktailDescription =
  "In my role as a React Developer at The Cocktail, I took a lead role in crafting dynamic web applications, utilizing my expertise in React. Working collaboratively with cross-functional teams, I actively contributed to the seamless implementation of front-end solutions. My responsibilities encompassed the successful integration of React web applications, ensuring the creation of robust and scalable user interfaces. Embracing agile development practices, I consistently delivered high-quality software within sprint timelines."
---

<Layout title="Welcome to Astro.">
  <div class="flex w-full">
    <div class="fixed inset-0 flex justify-center sm:px-8">
      <div class="flex w-full max-w-7xl lg:px-8">
        <div class="w-full ring-1 ring-zinc-100 bg-zinc-900 ring-zinc-300/20">
        </div>
      </div>
    </div><div class="relative flex w-full flex-col">
      <Header />
      <main class="flex-auto">
        <section class="sm:px-8 mt-12">
          <div class="mx-auto w-full max-w-7xl lg:px-8">
            <div class="mx-auto max-w-2xl lg:max-w-5xl px-4 sm:px-8 lg:px-12">
              <div class="max-w-2xl">
                <Image
                  src="/pablo-photo.webp"
                  class="rounded-full"
                  alt="Pablo's photo"
                  width={64}
                  height={64}
                />
                <h1
                  class="text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl mt-6"
                >
                  Hi, I’m Pablo
                </h1><p class="mt-6 text-base text-zinc-400 leading-7">
                  Software Engineer with more than 3 years of experience. Full
                  Stack developer specialized in Frontend. In my free time I
                  write some code. From Sevilla, Spain.
                </p><div class="mt-6 flex gap-6">
                  <a
                    class="group -m-1 p-1"
                    aria-label="Follow on LinkedIn"
                    href="https://www.linkedin.com/in/pablo-medina-rodr%C3%ADguez-a3a8b9135/"
                    ><svg
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      class="h-6 w-6 transition fill-zinc-400 group-hover:fill-zinc-300"
                      ><path
                        d="M18.335 18.339H15.67v-4.177c0-.996-.02-2.278-1.39-2.278-1.389 0-1.601 1.084-1.601 2.205v4.25h-2.666V9.75h2.56v1.17h.035c.358-.674 1.228-1.387 2.528-1.387 2.7 0 3.2 1.778 3.2 4.091v4.715zM7.003 8.575a1.546 1.546 0 01-1.548-1.549 1.548 1.548 0 111.547 1.549zm1.336 9.764H5.666V9.75H8.34v8.589zM19.67 3H4.329C3.593 3 3 3.58 3 4.297v15.406C3 20.42 3.594 21 4.328 21h15.338C20.4 21 21 20.42 21 19.703V4.297C21 3.58 20.4 3 19.666 3h.003z"
                      ></path></svg
                    ></a
                  ><a
                    class="group -m-1 p-1"
                    aria-label="Follow on GitHub"
                    href="https://github.com/PMedina25"
                    ><svg
                      viewBox="0 0 24 24"
                      aria-hidden="true"
                      class="h-6 w-6 transition fill-zinc-400 group-hover:fill-zinc-300"
                      ><path
                        fill-rule="evenodd"
                        clip-rule="evenodd"
                        d="M12 2C6.475 2 2 6.588 2 12.253c0 4.537 2.862 8.369 6.838 9.727.5.09.687-.218.687-.487 0-.243-.013-1.05-.013-1.91C7 20.059 6.35 18.957 6.15 18.38c-.113-.295-.6-1.205-1.025-1.448-.35-.192-.85-.667-.013-.68.788-.012 1.35.744 1.538 1.051.9 1.551 2.338 1.116 2.912.846.088-.666.35-1.115.638-1.371-2.225-.256-4.55-1.14-4.55-5.062 0-1.115.387-2.038 1.025-2.756-.1-.256-.45-1.307.1-2.717 0 0 .837-.269 2.75 1.051.8-.23 1.65-.346 2.5-.346.85 0 1.7.115 2.5.346 1.912-1.333 2.75-1.05 2.75-1.05.55 1.409.2 2.46.1 2.716.637.718 1.025 1.628 1.025 2.756 0 3.934-2.337 4.806-4.562 5.062.362.32.675.936.675 1.897 0 1.371-.013 2.473-.013 2.82 0 .268.188.589.688.486a10.039 10.039 0 0 0 4.932-3.74A10.447 10.447 0 0 0 22 12.253C22 6.588 17.525 2 12 2Z"
                      ></path></svg
                    ></a
                  >
                </div>
              </div>
            </div>
          </div>
        </section>
        <section id="experience" class="sm:px-8 mt-24 md:mt-28">
          <div class="mx-auto w-full max-w-7xl lg:px-8">
            <div
              class="grid grid-cols-1 gap-y-8 items-baseline md:grid-cols-4 mx-auto max-w-2xl lg:max-w-5xl px-4 sm:px-8 lg:px-12"
            >
              <h2
                class="text-lg font-semibold tracking-tight sm:text-xl text-zinc-100"
              >
                Experience
              </h2>
              <div class="md:col-span-3">
                <ul role="list" class="space-y-16">
                  <li class="flex flex-col items-start">
                    <ExperienceCard
                      title="Kairos DS"
                      role="Frontend Developer"
                      description={kairosDescription}
                      time="2023-Present"
                      image="/kairos-logo.svg"
                    />
                  </li><li class="flex flex-col items-start">
                    <ExperienceCard
                      title="The Cocktail"
                      role="Frontend Developer"
                      description={theCocktailDescription}
                      time="2021-2023"
                      image="/the-cocktail-logo.webp"
                    />
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </section>
      </main>
      <Footer />
    </div>
  </div>

  <style></style>
</Layout>
